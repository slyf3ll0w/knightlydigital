# Copy this file to .env.local and fill in the values

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Railway PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Finix payment processing (optional locally) — see CLAUDE.md "Payment processor"
# PAYMENT_PROCESSOR=finix
# FINIX_ENVIRONMENT=sandbox
# FINIX_API_USERNAME=
# FINIX_API_PASSWORD=
# FINIX_APPLICATION_ID=
# Published processing rates (defaults: card 2.9% + 30¢, ACH 0.75%) — keep in
# sync with the fee profile configured in the Finix dashboard
# WORKBENCH_CARD_FEE_BPS=290
# WORKBENCH_CARD_FEE_FIXED_CENTS=30
# WORKBENCH_ACH_FEE_BPS=75
# WORKBENCH_ACH_FEE_FIXED_CENTS=0
