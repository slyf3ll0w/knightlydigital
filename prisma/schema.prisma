generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy ─────────────────────────────────────────────────────────────────

model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  phone            String?
  email            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  website          String?
  logoUrl          String?
  timezone         String   @default("America/Chicago")
  surchargeEnabled Boolean  @default(false)
  surchargeRate    Decimal  @default(0.0300) @db.Decimal(5, 4)
  reviewLink       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users           User[]
  contacts        Contact[]
  requests        Request[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  workItems       WorkItem[]
  servicePlans    ServicePlan[]
  bookingRequests BookingRequest[]
  reviewRequests  ReviewRequest[]

  @@index([slug])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(TECH)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments JobAssignment[]
  notes       JobNote[]

  @@index([companyId])
  @@index([role])
}

enum Role {
  SUPERADMIN
  OWNER
  MANAGER
  TECH
}

// ─── Contacts (Clients) ──────────────────────────────────────────────────────

enum ContactStatus {
  LEAD
  ACTIVE
  ARCHIVED
}

model Contact {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  firstName        String
  lastName         String
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  notes            String?
  status           ContactStatus @default(LEAD)
  leadSource       String?
  paymentTermsDays Int           @default(30)
  hubToken         String        @unique @default(cuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  requests        Request[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  servicePlans    ServicePlan[]
  bookingRequests BookingRequest[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, lastName])
}

// ─── Requests ────────────────────────────────────────────────────────────────

enum RequestStatus {
  NEW
  CONVERTED
  ARCHIVED
}

model Request {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  requestNumber Int
  title         String
  details       String?
  status        RequestStatus @default(NEW)
  assessmentAt  DateTime?
  source        String        @default("internal") // internal | client_hub | booking_form
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  quotes Quote[]
  jobs   Job[]

  @@unique([companyId, requestNumber])
  @@index([companyId])
  @@index([companyId, status])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

enum JobStatus {
  ACTIVE
  REQUIRES_INVOICING
  ARCHIVED
}

model Job {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id])
  requestId    String?
  request      Request?  @relation(fields: [requestId], references: [id])
  jobNumber    Int
  title        String
  description  String?
  leadSource   String?
  status       JobStatus @default(ACTIVE)
  scheduledAt  DateTime?
  scheduledEnd DateTime?
  completedAt  DateTime?
  closedAt     DateTime?
  address      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments JobAssignment[]
  notes       JobNote[]
  photos      JobPhoto[]
  lineItems   JobLineItem[]
  quote       Quote?
  invoice     Invoice?

  @@unique([companyId, jobNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, scheduledAt])
}

model JobLineItem {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Decimal  @db.Decimal(10, 3)
  unitCost    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)

  @@index([jobId])
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@index([userId])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([jobId])
}

enum PhotoType {
  BEFORE
  AFTER
  GENERAL
}

model JobPhoto {
  id        String    @id @default(cuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  type      PhotoType @default(GENERAL)
  createdAt DateTime  @default(now())

  @@index([jobId])
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  AWAITING_RESPONSE
  APPROVED
  CHANGES_REQUESTED
  CONVERTED
  ARCHIVED
}

enum DepositType {
  NONE
  PERCENT
  FIXED
}

model Quote {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id])
  requestId     String?
  request       Request?    @relation(fields: [requestId], references: [id])
  jobId         String?     @unique // set when this quote is converted into a job
  job           Job?        @relation(fields: [jobId], references: [id])
  quoteNumber   Int
  title         String?
  status        QuoteStatus @default(DRAFT)
  subtotal      Decimal     @db.Decimal(10, 2)
  taxRate       Decimal?    @db.Decimal(5, 4)
  tax           Decimal?    @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  depositType   DepositType @default(NONE)
  depositValue  Decimal?    @db.Decimal(10, 2) // percent (0-100) or fixed dollars
  clientMessage String?
  disclaimer    String?
  notes         String?
  validUntil    DateTime?
  sentAt        DateTime?
  approvedAt    DateTime?
  signatureName String?
  changeRequest String?
  publicToken   String      @unique @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lineItems QuoteLineItem[]

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([contactId])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name        String  @default("")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitCost    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  isOptional  Boolean @default(false)
  optedOut    Boolean @default(false) // client unchecked this optional item in the hub
  sortOrder   Int     @default(0)

  @@index([quoteId])
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  PAST_DUE
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  jobId         String?       @unique
  job           Job?          @relation(fields: [jobId], references: [id])
  invoiceNumber Int
  subject       String?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxRate       Decimal?      @db.Decimal(5, 4)
  tax           Decimal?      @db.Decimal(10, 2)
  surcharge     Decimal?      @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  publicToken   String        @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]
  reminders PaymentReminder[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String  @default("")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  serviceDate DateTime?
  sortOrder   Int     @default(0)

  @@index([invoiceId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CARD
  ACH
  CASH
  CHECK
  CASH_APP
  PAYPAL
  VENMO
  ZELLE
  OTHER
}

model Payment {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id])
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  referenceNumber String?
  details         String?
  processorRef    String? // transaction id from the payment processor (card/ACH)
  surchargeAmount Decimal?      @db.Decimal(10, 2)
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@index([invoiceId])
  @@index([contactId])
}

model PaymentReminder {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String
  sentAt    DateTime

  @@index([invoiceId])
}

// ─── Price Book ───────────────────────────────────────────────────────────────

enum WorkItemType {
  SERVICE
  PRODUCT
}

model WorkItem {
  id          String       @id @default(cuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  name        String
  description String?
  type        WorkItemType @default(SERVICE)
  unitCost    Decimal?     @db.Decimal(10, 2)
  unitPrice   Decimal      @default(0) @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId])
  @@index([companyId, name])
}

// ─── Service Plans ────────────────────────────────────────────────────────────

enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model ServicePlan {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id])
  name        String
  description String?
  frequency   Frequency
  price       Decimal   @db.Decimal(10, 2)
  nextJobDate DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, nextJobDate])
}

// ─── Booking Requests (legacy public booking form) ───────────────────────────

enum BookingStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

model BookingRequest {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  service       String
  preferredDate DateTime?
  message       String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

// ─── Review Requests ──────────────────────────────────────────────────────────

model ReviewRequest {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  contactId String?
  jobId     String?
  email     String?
  phone     String?
  sentAt    DateTime
  method    String
  status    String   @default("sent")
  createdAt DateTime @default(now())

  @@index([companyId])
}
