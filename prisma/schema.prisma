generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy ─────────────────────────────────────────────────────────────────

model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  phone            String?
  email            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  website          String?
  logoUrl          String? // display URL; points at /api/logo/[id] for uploaded logos
  logoData         Bytes? // uploaded logo bytes (small files only; move to R2 with job photos)
  logoMime         String?
  brandColor       String? // hex accent used on client-facing pages (quotes, invoices, hub, booking)
  timezone         String   @default("America/Chicago")
  surchargeEnabled Boolean  @default(false)
  surchargeRate    Decimal  @default(0.0300) @db.Decimal(5, 4)
  reviewLink       String?
  bookingForm      Json? // booking/embed form config (custom fields etc.) — see lib/booking-form.ts
  industry         String? // onboarding answer; drives starter price book + future industry defaults
  // Team settings: who gets website/booking leads (null = company owner),
  // and whether SALES users can see invoices & payments for their leads.
  defaultLeadUserId String?
  salesSeePayments  Boolean @default(true)
  teamSize         String? // onboarding answers below — analytics/marketing
  currentSoftware  String?
  topPriority      String?
  referralSource   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users           User[]
  contacts        Contact[]
  requests        Request[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  workItems       WorkItem[]
  servicePlans    ServicePlan[]
  bookingRequests BookingRequest[]
  reviewRequests  ReviewRequest[]
  appointments    Appointment[]
  contactFieldDefs ContactFieldDef[]
  webForms        WebForm[]

  @@index([slug])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(TECH)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments      JobAssignment[]
  notes            JobNote[]
  assignedContacts Contact[]       @relation("AssignedContacts")
  appointments     Appointment[]   @relation("AppointmentAssignee")

  @@index([companyId])
  @@index([role])
}

enum Role {
  SUPERADMIN
  OWNER
  ADMIN // pretty much everything except managing owners/admins' roles
  USER // sales + tech combined, no admin powers (UI label: "Sales + Tech")
  SALES // sells: assigned leads, their requests/quotes
  TECH // performs: assigned jobs + schedule, no pricing
}

// ─── Contacts (Clients) ──────────────────────────────────────────────────────

enum ContactFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

// Company-defined custom fields on clients ("Gate code", "Property size").
// Definitions live here; each contact stores values in customFields Json
// keyed by definition id. Archiving (isActive=false) hides a field without
// destroying saved values.
model ContactFieldDef {
  id        String           @id @default(cuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  label     String
  type      ContactFieldType @default(TEXT)
  options   Json? // SELECT: string[] of choices
  required  Boolean          @default(false)
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  @@index([companyId, isActive])
}

enum ContactStatus {
  LEAD
  ACTIVE
  ARCHIVED
}

model Contact {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  firstName        String
  lastName         String
  companyName      String? // the client's business name (CRM imports usually have one)
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  notes            String?
  status           ContactStatus @default(LEAD)
  leadSource       String?
  // Lead ownership: SALES/USER roles only see contacts assigned to them
  assignedToId     String?
  assignedTo       User?         @relation("AssignedContacts", fields: [assignedToId], references: [id])
  // CSV import provenance — lets "Undo this import" find the batch
  importBatchId    String?
  // Values for the company's ContactFieldDef custom fields: { [defId]: value }
  customFields     Json?
  paymentTermsDays Int           @default(30)
  hubToken         String        @unique @default(cuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  requests        Request[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  servicePlans    ServicePlan[]
  bookingRequests BookingRequest[]
  appointments    Appointment[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, lastName])
  @@index([companyId, assignedToId])
  @@index([companyId, importBatchId])
}

// ─── Requests ────────────────────────────────────────────────────────────────

enum RequestStatus {
  NEW
  CONVERTED
  ARCHIVED
}

model Request {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  requestNumber Int
  title         String
  details       String?
  status        RequestStatus @default(NEW)
  preferredDate DateTime? // client's requested date from booking-type forms (date-only, noon anchor)
  source        String        @default("internal") // internal | client_hub | booking_form
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  quotes       Quote[]
  jobs         Job[]
  appointments Appointment[]

  @@unique([companyId, requestNumber])
  @@index([companyId])
  @@index([companyId, status])
}

// ─── Web forms (public booking/inquiry/service-request forms) ────────────────

enum WebFormType {
  INQUIRY // collect info → lead + request
  BOOKING // + preferred date for an estimate
  SERVICE_REQUEST // pick services → auto-creates an invoice (draft or sent)
}

// A company can run any number of public forms, each fully customizable
// (header, every field label, appearance). The company's pre-multi-form
// config (Company.bookingForm Json) is lazily migrated into the row marked
// isDefault, which keeps the original /book/[slug] and /embed/[slug] URLs
// (and snippets already on customer sites) working unchanged.
model WebForm {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  name      String // internal label, also the request title fallback
  slug      String // URL part: /book/[companySlug]/[slug]
  type      WebFormType @default(INQUIRY)
  isDefault Boolean     @default(false)
  isActive  Boolean     @default(true)
  config    Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
}

// ─── Appointments (sales meetings / estimates) ───────────────────────────────

enum AppointmentType {
  PHONE_CALL
  VIDEO_CALL
  IN_PERSON
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// A scheduled conversation with a client — estimate visit, sales call,
// discovery meeting. Sits between Request and Quote in the lifecycle and
// shows on the schedule next to jobs. Replaces Request.assessmentAt.
model Appointment {
  id           String            @id @default(cuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  contactId    String
  contact      Contact           @relation(fields: [contactId], references: [id])
  requestId    String?
  request      Request?          @relation(fields: [requestId], references: [id])
  assignedToId String?
  assignedTo   User?             @relation("AppointmentAssignee", fields: [assignedToId], references: [id])
  title        String // "Estimate", "Sales call", ...
  type         AppointmentType
  status       AppointmentStatus @default(SCHEDULED)
  scheduledAt  DateTime
  scheduledEnd DateTime?
  // Date-only scheduling: anchored at noon, shown in the calendar's "Anytime" row
  scheduledAnytime Boolean  @default(false)
  address          String? // required for IN_PERSON (API-enforced)
  meetingLink      String? // optional pasted URL for VIDEO_CALL
  notes            String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId, scheduledAt])
  @@index([companyId, status])
  @@index([contactId])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

enum JobStatus {
  ACTIVE
  REQUIRES_INVOICING
  ARCHIVED
}

model Job {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id])
  requestId    String?
  request      Request?  @relation(fields: [requestId], references: [id])
  jobNumber    Int
  title        String
  description  String?
  leadSource   String?
  status       JobStatus @default(ACTIVE)
  scheduledAt  DateTime?
  scheduledEnd DateTime?
  // Date-only scheduling: scheduledAt anchored at T12:00, shown in the
  // calendar's "Anytime" row rather than at a clock position.
  scheduledAnytime Boolean @default(false)
  completedAt  DateTime?
  closedAt     DateTime?
  address      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments JobAssignment[]
  notes       JobNote[]
  photos      JobPhoto[]
  lineItems   JobLineItem[]
  quote       Quote?
  invoice     Invoice?

  @@unique([companyId, jobNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, scheduledAt])
}

model JobLineItem {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Decimal  @db.Decimal(10, 3)
  unitCost    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)

  @@index([jobId])
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@index([userId])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([jobId])
}

enum PhotoType {
  BEFORE
  AFTER
  GENERAL
}

model JobPhoto {
  id        String    @id @default(cuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  type      PhotoType @default(GENERAL)
  createdAt DateTime  @default(now())

  @@index([jobId])
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  AWAITING_RESPONSE
  APPROVED
  CHANGES_REQUESTED
  CONVERTED
  ARCHIVED
}

enum DepositType {
  NONE
  PERCENT
  FIXED
}

model Quote {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id])
  requestId     String?
  request       Request?    @relation(fields: [requestId], references: [id])
  jobId         String?     @unique // set when this quote is converted into a job
  job           Job?        @relation(fields: [jobId], references: [id])
  quoteNumber   Int
  title         String?
  status        QuoteStatus @default(DRAFT)
  subtotal      Decimal     @db.Decimal(10, 2)
  taxRate       Decimal?    @db.Decimal(5, 4)
  tax           Decimal?    @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  depositType   DepositType @default(NONE)
  depositValue  Decimal?    @db.Decimal(10, 2) // percent (0-100) or fixed dollars
  clientMessage String?
  disclaimer    String?
  notes         String?
  validUntil    DateTime?
  sentAt        DateTime?
  approvedAt    DateTime?
  signatureName String?
  changeRequest String?
  publicToken   String      @unique @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lineItems QuoteLineItem[]

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([contactId])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name        String  @default("")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitCost    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  isOptional  Boolean @default(false)
  optedOut    Boolean @default(false) // client unchecked this optional item in the hub
  sortOrder   Int     @default(0)

  @@index([quoteId])
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  PAST_DUE
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  jobId         String?       @unique
  job           Job?          @relation(fields: [jobId], references: [id])
  invoiceNumber Int
  subject       String?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxRate       Decimal?      @db.Decimal(5, 4)
  tax           Decimal?      @db.Decimal(10, 2)
  surcharge     Decimal?      @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  publicToken   String        @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]
  reminders PaymentReminder[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String  @default("")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  serviceDate DateTime?
  sortOrder   Int     @default(0)

  @@index([invoiceId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CARD
  ACH
  CASH
  CHECK
  CASH_APP
  PAYPAL
  VENMO
  ZELLE
  OTHER
}

model Payment {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id])
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  referenceNumber String?
  details         String?
  processorRef    String? // transaction id from the payment processor (card/ACH)
  surchargeAmount Decimal?      @db.Decimal(10, 2)
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@index([invoiceId])
  @@index([contactId])
}

model PaymentReminder {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String
  sentAt    DateTime

  @@index([invoiceId])
}

// ─── Price Book ───────────────────────────────────────────────────────────────

enum WorkItemType {
  SERVICE
  PRODUCT
}

model WorkItem {
  id          String       @id @default(cuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  name        String
  description String?
  type        WorkItemType @default(SERVICE)
  unitCost    Decimal?     @db.Decimal(10, 2)
  unitPrice   Decimal      @default(0) @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId])
  @@index([companyId, name])
}

// ─── Service Plans ────────────────────────────────────────────────────────────

enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model ServicePlan {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id])
  name        String
  description String?
  frequency   Frequency
  price       Decimal   @db.Decimal(10, 2)
  nextJobDate DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, nextJobDate])
}

// ─── Booking Requests (legacy public booking form) ───────────────────────────

enum BookingStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

model BookingRequest {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  service       String
  preferredDate DateTime?
  message       String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

// ─── Review Requests ──────────────────────────────────────────────────────────

model ReviewRequest {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  contactId String?
  jobId     String?
  email     String?
  phone     String?
  sentAt    DateTime
  method    String
  status    String   @default("sent")
  createdAt DateTime @default(now())

  @@index([companyId])
}
