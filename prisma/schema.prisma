generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy ─────────────────────────────────────────────────────────────────

model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  phone            String?
  email            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  website          String?
  logoUrl          String?
  timezone         String   @default("America/Chicago")
  surchargeEnabled Boolean  @default(false)
  surchargeRate    Decimal  @default(0.0300) @db.Decimal(5, 4)
  reviewLink       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users           User[]
  contacts        Contact[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  servicePlans    ServicePlan[]
  bookingRequests BookingRequest[]
  reviewRequests  ReviewRequest[]

  @@index([slug])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(TECH)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments JobAssignment[]
  notes       JobNote[]

  @@index([companyId])
  @@index([role])
}

enum Role {
  SUPERADMIN
  OWNER
  MANAGER
  TECH
}

// ─── Contacts ────────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  servicePlans    ServicePlan[]
  bookingRequests BookingRequest[]

  @@index([companyId])
  @@index([companyId, lastName])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

enum JobStatus {
  LEAD
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  INVOICED
  PAID
}

model Job {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id])
  jobNumber    Int
  title        String
  description  String?
  status       JobStatus @default(LEAD)
  scheduledAt  DateTime?
  scheduledEnd DateTime?
  completedAt  DateTime?
  address      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments JobAssignment[]
  notes       JobNote[]
  photos      JobPhoto[]
  quote       Quote?
  invoice     Invoice?

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, scheduledAt])
  @@unique([companyId, jobNumber])
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@index([userId])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([jobId])
}

enum PhotoType {
  BEFORE
  AFTER
  GENERAL
}

model JobPhoto {
  id        String    @id @default(cuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  type      PhotoType @default(GENERAL)
  createdAt DateTime  @default(now())

  @@index([jobId])
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

model Quote {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  contactId   String
  contact     Contact     @relation(fields: [contactId], references: [id])
  jobId       String?     @unique
  job         Job?        @relation(fields: [jobId], references: [id])
  quoteNumber Int
  status      QuoteStatus @default(DRAFT)
  subtotal    Decimal     @db.Decimal(10, 2)
  taxRate     Decimal?    @db.Decimal(5, 4)
  tax         Decimal?    @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  notes       String?
  validUntil  DateTime?
  acceptedAt  DateTime?
  sentAt      DateTime?
  publicToken String      @unique @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lineItems QuoteLineItem[]

  @@index([companyId])
  @@index([contactId])
  @@unique([companyId, quoteNumber])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)

  @@index([quoteId])
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  jobId         String?       @unique
  job           Job?          @relation(fields: [jobId], references: [id])
  invoiceNumber Int
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxRate       Decimal?      @db.Decimal(5, 4)
  tax           Decimal?      @db.Decimal(10, 2)
  surcharge     Decimal?      @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  publicToken   String        @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]
  reminders PaymentReminder[]

  @@index([companyId])
  @@index([companyId, status])
  @@unique([companyId, invoiceNumber])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)

  @@index([invoiceId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CARD
  ACH
  CASH
  CHECK
  OTHER
}

model Payment {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  processorRef    String?
  surchargeAmount Decimal?      @db.Decimal(10, 2)
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@index([invoiceId])
}

model PaymentReminder {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String
  sentAt    DateTime

  @@index([invoiceId])
}

// ─── Service Plans ────────────────────────────────────────────────────────────

enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model ServicePlan {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id])
  name        String
  description String?
  frequency   Frequency
  price       Decimal   @db.Decimal(10, 2)
  nextJobDate DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, nextJobDate])
}

// ─── Booking Requests ─────────────────────────────────────────────────────────

enum BookingStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

model BookingRequest {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  service       String
  preferredDate DateTime?
  message       String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

// ─── Review Requests ──────────────────────────────────────────────────────────

model ReviewRequest {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  contactId String?
  jobId     String?
  email     String?
  phone     String?
  sentAt    DateTime
  method    String
  status    String   @default("sent")
  createdAt DateTime @default(now())

  @@index([companyId])
}
