generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy ─────────────────────────────────────────────────────────────────

model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  phone            String?
  email            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  website          String?
  logoUrl          String? // display URL; points at /api/logo/[id] for uploaded logos
  logoData         Bytes? // uploaded logo bytes (small files only; move to R2 with job photos)
  logoMime         String?
  brandColor       String? // primary brand hex: headers/surfaces on client-facing pages + app accent
  brandColorSecondary String? // secondary brand hex: buttons/accents; falls back to brandColor
  // Client-document header hex (quotes, invoices, emails, hub, portal) —
  // decoupled from the in-app primary; falls back to brandColor when unset.
  documentColor    String?
  // App-wide Google Font override for the signed-in app (same free-text
  // Google Font convention as booking-form appearance.font). Body + display
  // text; ledger numerals/stamps stay Oxanium. Null = stock Inter/Oxanium.
  brandFont        String?
  // Advanced customization: per-section hue overrides for the app's color
  // language ({ jobs: "#F97316", ... } — keys/validation in lib/section-colors.ts).
  // {} or null = the stock palette.
  sectionColors    Json?
  logoWallpaper    Boolean  @default(false) // legacy wallpaper toggle — superseded by `wallpaper`; null wallpaper + true here still means "logo"
  // App wallpaper behind every page: "none" | "logo" | "grid" | "dots" |
  // "blueprint" | "topo" | "pinstripe" (see WALLPAPERS in lib/wallpapers.ts).
  // Null = not chosen yet → falls back to logoWallpaper for pre-existing tenants.
  wallpaper        String?
  sidebarTheme     String   @default("black") // desktop sidebar: "black" | "white" | "gray"
  sidebarLogoColor String? // hex backdrop behind the sidebar logo panel; null = white
  timezone         String   @default("America/Chicago")
  surchargeEnabled Boolean  @default(false)
  surchargeRate    Decimal  @default(0.0300) @db.Decimal(5, 4)
  // Finix payment processing (Streamflaire Payments). The identity/merchant pair
  // comes from the hosted onboarding form; onboardingState mirrors Finix's
  // merchant onboarding_state (PROVISIONING | APPROVED | REJECTED |
  // UPDATE_REQUESTED). Online charges only run when APPROVED.
  finixOnboardingFormId String?
  finixIdentityId       String?
  finixMerchantId       String? @unique
  finixOnboardingState  String?
  // Payment verification is mandatory: new companies are held at /app/activate
  // until Finix underwriting approves them. This flag exempts a company from
  // that gate (test accounts, comped users) — flipped only from the superadmin
  // console.
  paymentsWaived Boolean @default(false)
  // Company-wide default deposit, applied to preset services with no deposit of
  // their own and used to prefill custom quotes. NONE = no default deposit.
  defaultDepositType  DepositType @default(NONE)
  defaultDepositValue Decimal?    @db.Decimal(10, 2) // percent (0-100) or fixed dollars
  reviewLink       String?
  // "On my way" text template ({{placeholder}} substitution per lib/messaging.ts);
  // null = the built-in default. Sent from the tech's own phone via an sms: link.
  onMyWayTemplate  String?
  bookingForm      Json? // booking/embed form config (custom fields etc.) — see lib/booking-form.ts
  // Online booking (self-scheduling). businessHours: { mon: [{start:"08:00",end:"17:00"}], ... }
  // per lib/business-hours.ts; null = default weekday hours. serviceZips empty = no
  // service-area restriction. arrivalWindowMinutes = width of the promised window.
  businessHours        Json?
  serviceZips          String[] @default([])
  arrivalWindowMinutes Int      @default(120)
  // Granularity of the even time-slot picker when staff schedule jobs/appointments
  // in-app (minutes). Resolved through lib/scheduling.ts, which is structured so a
  // future route-management system and per-service-type overrides can refine it.
  schedulingIntervalMinutes Int  @default(30)
  industry         String? // onboarding answer; drives starter price book + future industry defaults
  // AI setup wizard: stamped when the owner applies OR dismisses it — hides
  // the dashboard card either way (the Settings entry stays available)
  setupWizardAt    DateTime?
  // Display name for the in-app AI assistant; null = the default ("Atlas")
  assistantName    String?
  // Platform suspension (superadmin-only): set → the tenant app and public
  // booking/leads/payments are disabled, data stays intact until support
  // reinstates. Deletion is separate and permanent.
  suspendedAt      DateTime?
  suspendedReason  String?
  // Team settings: who gets website/booking leads (null = company owner),
  // and whether SALES users can see invoices & payments for their leads.
  defaultLeadUserId String?
  salesSeePayments  Boolean @default(true)
  // Lead intake webhook (Zapier/Make/ad connectors): POST /api/public/leads/[token].
  // null = intake off; rotating the token kills old integrations instantly.
  leadWebhookToken String? @unique
  // Hide the board's Converted section (recently-won cards) to save screen space
  hideConvertedLeads Boolean @default(false)
  teamSize         String? // onboarding answers below — analytics/marketing
  currentSoftware  String?
  topPriority      String?
  referralSource   String?
  // Custom sending domain (Resend Domains API): client emails send from
  // `${emailFromLocal}@${emailDomain}` once status is "verified"; every other
  // state falls back to the platform EMAIL_FROM. Rails only until the Resend
  // plan supports tenant domains — UI/API gate on EMAIL_DOMAINS_ENABLED.
  emailDomain        String?  @unique // apex or subdomain the company verified (e.g. "summitplumbing.com")
  emailDomainId      String? // Resend domain id — the handle for verify/status/delete
  emailDomainStatus  String? // Resend status mirror: "pending" | "verified" | "failed" | "temporary_failure"
  emailDomainRecords Json? // DNS records Resend wants ([{record,name,type,value,status}]) — shown in Settings
  emailFromLocal     String? // local part of the From address; null = "notifications"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users           User[]
  contacts        Contact[]
  requests        Request[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  workItems       WorkItem[]
  subscriptions   Subscription[]
  bookingRequests BookingRequest[]
  reviewRequests  ReviewRequest[]
  appointments    Appointment[]
  contactFieldDefs  ContactFieldDef[]
  webForms          WebForm[]
  contractTemplates ContractTemplate[]
  contracts         Contract[]
  expenses          Expense[]
  teamMessages      TeamMessage[]
  chatChannels      ChatChannel[]
  pipelineStages    PipelineStage[]
  timeBlocks        TimeBlock[]
  timeEntries       TimeEntry[]
  locationPings     LocationPing[]
  quickBooks        QuickBooksConnection?
  inviteCode        InviteCode?

  @@index([slug])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(TECH)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  phone        String?
  isActive     Boolean  @default(true)
  // Accepts online-booking slots: this user's free time feeds the public slot
  // picker and tentative appointments land on them. Off by default — owners
  // opt team members in from the Team page.
  bookable     Boolean  @default(false)
  // Profile picture (small client-resized square; same bytes-in-DB pattern
  // as Company.logoData — move to R2 with job photos when volume grows)
  avatarData      Bytes?
  avatarMime      String?
  avatarUpdatedAt DateTime?
  // First-visit guided tour; null = hasn't seen it (fires on next dashboard visit)
  tourCompletedAt DateTime?
  // Team chat: last time this user opened the chat (drives the unread badge)
  chatLastSeenAt  DateTime?
  // Internal labor cost per hour — feeds job labor costing from time entries.
  // Never shown to techs (pricing gate); null = don't cost this user's time.
  hourlyCost   Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments      JobAssignment[]
  notes            JobNote[]
  contactNotes     ContactNote[]
  assignedContacts Contact[]       @relation("AssignedContacts")
  appointments     Appointment[]   @relation("AppointmentAssignee")
  teamMessages     TeamMessage[]
  receivedTeamMessages TeamMessage[] @relation("ReceivedTeamMessages")
  chatThreadStates ChatThreadState[]
  chatChannelMembers ChatChannelMember[]
  pushSubscriptions PushSubscription[]
  passwordResetTokens PasswordResetToken[]
  superadminLoginCodes SuperadminLoginCode[]
  timeBlocks       TimeBlock[]     @relation("TimeBlockUser")
  timeEntries      TimeEntry[]
  locationPings    LocationPing[]
  checklistChecks  JobChecklistItem[]

  @@index([companyId])
  @@index([role])
}

// Self-serve password reset. We store only a SHA-256 hash of the emailed token,
// so a database leak can't be used to reset anyone's password. Single-use
// (usedAt) and short-lived (expiresAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Second factor for /superadmin/login: a 6-digit code emailed after the
// password checks out. SHA-256 hash only, one live code per user (issuing
// replaces), short-lived, consumed on successful sign-in, and attempt-capped
// so the 1M keyspace can't be walked.
model SuperadminLoginCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Push notifications ──────────────────────────────────────────────────────

// One row per browser/device a user turned notifications on for (a user can
// have several: phone app + desktop browser). Dead endpoints are pruned when
// the push service answers 404/410 on send.
model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Web: the push-service endpoint URL. Native (ios/android): the FCM device token.
  endpoint String @unique
  platform String @default("web") // "web" | "ios" | "android"
  // Web-push encryption keys — null for native subscriptions
  p256dh    String?
  auth      String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Team chat ───────────────────────────────────────────────────────────────

// A conversation: the built-in company-wide "Everyone" channel (one per
// company, no member rows — visibility is the whole company), or a
// member-created DM (2 members, name null) / group chat (2+ members, named).
// No DMs or groups exist until someone creates them.
model ChatChannel {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isEveryone    Boolean   @default(false)
  name          String? // groups only; DMs display the other member's name
  createdById   String?
  // Thread-list ordering without joining messages
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  members  ChatChannelMember[]
  messages TeamMessage[]

  @@index([companyId, lastMessageAt])
}

// Membership + per-channel read marker (the Everyone channel reuses
// User.chatLastSeenAt instead).
model ChatChannelMember {
  id         String      @id @default(cuid())
  channelId  String
  channel    ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt DateTime?
  createdAt  DateTime    @default(now())

  @@unique([channelId, userId])
  @@index([userId])
}

// One chat message. channelId is the home of every message written since the
// channels rework; recipientId is the legacy pre-channels DM pointer, kept
// only so scripts/migrate-chat-channels.mjs can map old rows.
model TeamMessage {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channelId   String?
  channel     ChatChannel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?     @relation("ReceivedTeamMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String
  editedAt    DateTime?
  // Soft delete: body is wiped, a "message deleted" tombstone stays in the thread
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  reactions TeamMessageReaction[]

  @@index([channelId, createdAt])
  @@index([companyId, recipientId, createdAt])
  @@index([recipientId, userId])
}

// iMessage-style tapbacks: one row per user+emoji per message, toggled off by
// deleting the row — storage stays tiny.
model TeamMessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   TeamMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// Per-DM-thread read markers (the company channel reuses User.chatLastSeenAt).
// threadKey = the DM peer's user id. One row per opened thread per user.
model ChatThreadState {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadKey  String
  lastSeenAt DateTime @default(now())

  @@unique([userId, threadKey])
}

enum Role {
  SUPERADMIN
  OWNER
  ADMIN // pretty much everything except managing owners/admins' roles
  USER // sales + tech combined, no admin powers (UI label: "Sales + Tech")
  SALES // sells: assigned leads, their requests/quotes
  TECH // performs: assigned jobs + schedule, no pricing
}

// ─── Public roadmap (Upcoming Features board) ────────────────────────────────

enum RoadmapCategory {
  FEATURE
  BUG
  QOL // quality of life
}

// Product-wide (not company-scoped): the public "what's coming / what shipped"
// board at /roadmap. Anyone can view; only the allowlisted editor accounts in
// lib/roadmap.ts can write.
model RoadmapItem {
  id           String          @id @default(cuid())
  category     RoadmapCategory
  title        String
  details      String? // public note — shows on the board for everyone
  privateNotes String? // editors-only note — stripped server-side for everyone else
  shippedAt    DateTime? // null = upcoming; set = shipped (the checkbox)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([category, shippedAt])
}

// ─── Contacts (Clients) ──────────────────────────────────────────────────────

enum ContactFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

// Company-defined custom fields on clients ("Gate code", "Property size").
// Definitions live here; each contact stores values in customFields Json
// keyed by definition id. Archiving (isActive=false) hides a field without
// destroying saved values.
model ContactFieldDef {
  id        String           @id @default(cuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  label     String
  type      ContactFieldType @default(TEXT)
  options   Json? // SELECT: string[] of choices
  required  Boolean          @default(false)
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  @@index([companyId, isActive])
}

enum ContactStatus {
  LEAD
  ACTIVE
  ARCHIVED
}

// ─── Lead pipeline (kanban board) ────────────────────────────────────────────

// App events that can auto-advance a lead's card to a stage claiming them.
// Cards only move FORWARD on triggers — a quote re-send never demotes a lead.
enum PipelineTrigger {
  REQUEST_CREATED
  APPOINTMENT_SCHEDULED
  QUOTE_SENT
  QUOTE_APPROVED
}

// One column on the company's Leads board. Fully customizable: rename,
// recolor, reorder, add, delete (delete moves its cards to the first stage).
// Defaults seed on first board visit — see lib/pipeline.ts.
model PipelineStage {
  id            String           @id @default(cuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id])
  name          String
  color         String? // hex accent for the column header; null = console ink
  sortOrder     Int              @default(0)
  // The built-in terminal "Converted" section (one per company, always last,
  // undeletable): quote approvals and other wins land cards here while the
  // contact becomes an ACTIVE client. Hidden via Company.hideConvertedLeads.
  isConverted   Boolean          @default(false)
  autoAdvanceOn PipelineTrigger?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  contacts Contact[]

  @@index([companyId, sortOrder])
}

model Contact {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  firstName        String
  lastName         String
  companyName      String? // the client's business name (CRM imports usually have one)
  email            String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  notes            String?
  status           ContactStatus @default(LEAD)
  leadSource       String?
  // Lead pipeline (kanban): a set stage = a card on the Leads board. LEAD
  // contacts always carry a stage; ACTIVE clients re-enter when they submit
  // a new request (their card shows a Repeat badge). Won clears the stage and
  // stamps wonAt; Lost clears it with a reason (leads also archive).
  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])
  pipelineOrder   Int            @default(0) // manual sort within the column
  stageChangedAt  DateTime? // drives the card's "Nd in stage" aging
  wonAt           DateTime? // last win — insights funnel
  timesWon        Int       @default(0) // Repeat badge = won before the current run
  lostAt          DateTime?
  lostReason      String?
  // Lead ownership: SALES/USER roles only see contacts assigned to them
  assignedToId     String?
  assignedTo       User?         @relation("AssignedContacts", fields: [assignedToId], references: [id])
  // CSV import provenance — lets "Undo this import" find the batch
  importBatchId    String?
  // Values for the company's ContactFieldDef custom fields: { [defId]: value }
  customFields     Json?
  paymentTermsDays Int           @default(30)
  // Payment processor's customer/vault token — populated once a card is saved
  // on file (processor goes live). Recurring billing auto-charges when set.
  processorCustomerRef String?
  // Finix buyer Identity (IDxxx) — created on the contact's first online
  // payment and reused after. NOT a chargeable token (that's
  // processorCustomerRef, which stays null until card-on-file ships).
  finixBuyerIdentityId String?
  // Provider SMS (Telnyx): set when the client texts STOP to our number —
  // automated texts (reminders, quote/invoice links) skip them. Telnyx also
  // blocks at their edge; this flag keeps our senders honest and visible.
  smsOptOut        Boolean       @default(false)
  hubToken         String        @unique @default(cuid())
  // Last time the client opened their hub (beacon-stamped, no push — shown on
  // the contact page as "Portal · last visit")
  hubLastVisitAt   DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  requests        Request[]
  jobs            Job[]
  quotes          Quote[]
  invoices        Invoice[]
  payments        Payment[]
  subscriptions   Subscription[]
  bookingRequests BookingRequest[]
  appointments    Appointment[]
  contracts       Contract[]
  contactNotes    ContactNote[]
  addresses       ContactAddress[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, lastName])
  @@index([companyId, assignedToId])
  @@index([companyId, importBatchId])
  @@index([companyId, pipelineStageId])
}

// Additional service addresses (rental properties, second locations, ...).
// The contact's flat address/city/state/zip stays the primary; these are
// extras, offered wherever a job/appointment address gets picked.
model ContactAddress {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label     String? // "Rental on 5th St", "Office", ...
  address   String
  city      String?
  state     String?
  zip       String?
  createdAt DateTime @default(now())

  @@index([contactId])
}

// ─── Requests ────────────────────────────────────────────────────────────────

enum RequestStatus {
  NEW
  NEEDS_APPROVAL // self-scheduled booking awaiting Accept and Schedule / Decline
  CONVERTED
  ARCHIVED
}

model Request {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  requestNumber Int
  title         String
  details       String?
  status        RequestStatus @default(NEW)
  preferredDate DateTime? // client's requested date from booking-type forms (date-only, noon anchor)
  source        String        @default("internal") // internal | client_hub | booking_form
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  quotes       Quote[]
  jobs         Job[]
  appointments Appointment[]

  @@unique([companyId, requestNumber])
  @@index([companyId])
  @@index([companyId, status])
}

// ─── Business expenses (owner/admin: profit tracking + CSV export) ───────────

model Expense {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  description String
  category    String?
  amount      Decimal  @db.Decimal(10, 2)
  incurredAt  DateTime // transaction date (date-only, noon anchor)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([companyId, incurredAt])
}

// ─── Client notes (same shape as job notes) ──────────────────────────────────

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([contactId])
}

// ─── Service contracts (templates + e-sign) ──────────────────────────────────

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  VOID
}

// Reusable contract text the company writes once ("Lawn Care Agreement").
// {{client_name}}, {{company_name}}, {{date}} placeholders fill at creation.
model ContractTemplate {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  body      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
  workItems WorkItem[]

  @@index([companyId, isActive])
}

// A contract issued to a client — body snapshotted from the template, signed
// with a typed signature on the public /contract/[token] page (same e-sign
// approach as quote approval: typed name + timestamp + IP).
model Contract {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact           @relation(fields: [contactId], references: [id])
  templateId    String?
  template      ContractTemplate? @relation(fields: [templateId], references: [id])
  // Agreement attached to a specific quote — gates quote→job conversion when
  // the quote contains agreement-requiring services
  quoteId       String?
  quote         Quote?            @relation(fields: [quoteId], references: [id])
  title         String
  body          String            @db.Text
  status        ContractStatus    @default(DRAFT)
  publicToken   String            @unique @default(cuid())
  sentAt        DateTime?
  // Client opened the public /contract page (beacon-stamped — see /api/public/viewed)
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int               @default(0)
  signatureName String?
  signedAt      DateTime?
  signedFromIp  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId, status])
  @@index([contactId])
}

// ─── Web forms (public booking/inquiry/service-request forms) ────────────────

enum WebFormType {
  INQUIRY // collect info → lead + request
  BOOKING // + preferred date for an estimate
  SERVICE_REQUEST // pick services → auto-creates an invoice (draft or sent)
}

// A company can run any number of public forms, each fully customizable
// (header, every field label, appearance). The company's pre-multi-form
// config (Company.bookingForm Json) is lazily migrated into the row marked
// isDefault, which keeps the original /book/[slug] and /embed/[slug] URLs
// (and snippets already on customer sites) working unchanged.
model WebForm {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  name      String // internal label, also the request title fallback
  slug      String // URL part: /book/[companySlug]/[slug]
  type      WebFormType @default(INQUIRY)
  isDefault Boolean     @default(false)
  isActive  Boolean     @default(true)
  config    Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
}

// ─── Appointments (sales meetings / estimates) ───────────────────────────────

enum AppointmentType {
  PHONE_CALL
  VIDEO_CALL
  IN_PERSON
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// A scheduled conversation with a client — estimate visit, sales call,
// discovery meeting. Sits between Request and Quote in the lifecycle and
// shows on the schedule next to jobs. Replaces Request.assessmentAt.
model Appointment {
  id           String            @id @default(cuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  contactId    String
  contact      Contact           @relation(fields: [contactId], references: [id])
  requestId    String?
  request      Request?          @relation(fields: [requestId], references: [id])
  assignedToId String?
  assignedTo   User?             @relation("AppointmentAssignee", fields: [assignedToId], references: [id])
  title        String // "Estimate", "Sales call", ...
  type         AppointmentType
  status       AppointmentStatus @default(SCHEDULED)
  scheduledAt  DateTime
  scheduledEnd DateTime?
  // Date-only scheduling: anchored at noon, shown in the calendar's "Anytime" row
  scheduledAnytime Boolean  @default(false)
  // Self-scheduled online booking awaiting owner approval. Renders dashed on
  // the schedule; blocks the slot until accepted (clears this) or declined
  // (cancels the appointment). Internal creates are never tentative.
  tentative        Boolean  @default(false)
  address          String? // required for IN_PERSON (API-enforced)
  meetingLink      String? // optional pasted URL for VIDEO_CALL
  notes            String?
  completedAt      DateTime?
  // Client reminder emails (online-booked appointments): each stage fires
  // once, tracked here like PaymentReminder rows track dunning stages.
  reminderDaySentAt  DateTime?
  reminderHourSentAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId, scheduledAt])
  @@index([companyId, status])
  @@index([contactId])
}

// ─── Time blocks ──────────────────────────────────────────────────────────────

// Blocked-off time on the schedule — personal ("dentist", day off) or, when
// userId is null, company-wide (holiday, team meeting; owners/admins only).
// Blocks render striped on the calendar and subtract from online-booking
// availability like any other busy interval.
model TimeBlock {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  // null = everyone in the company
  userId      String?
  user        User?    @relation("TimeBlockUser", fields: [userId], references: [id], onDelete: Cascade)
  createdById String
  title       String   @default("Blocked off")
  // All-day blocks still store the full day span (00:00 → 23:59:59) so the
  // booking-availability math needs no special case; the flag only moves
  // rendering into the calendar's "Anytime" row.
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, startAt])
  @@index([userId])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

enum JobStatus {
  ACTIVE
  REQUIRES_INVOICING
  ARCHIVED
}

model Job {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id])
  requestId    String?
  request      Request?  @relation(fields: [requestId], references: [id])
  // Set when this job was auto-generated by a recurring subscription cycle
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  jobNumber    Int
  title        String
  description  String?
  leadSource   String?
  status       JobStatus @default(ACTIVE)
  scheduledAt  DateTime?
  scheduledEnd DateTime?
  // Date-only scheduling: scheduledAt anchored at T12:00, shown in the
  // calendar's "Anytime" row rather than at a clock position.
  scheduledAnytime Boolean @default(false)
  completedAt  DateTime?
  closedAt     DateTime?
  address      String?
  // Last time a tech sent the client an "on my way" text (from their own phone)
  onMyWaySentAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments JobAssignment[]
  notes       JobNote[]
  photos      JobPhoto[]
  lineItems   JobLineItem[]
  timeEntries TimeEntry[]
  checklistItems JobChecklistItem[]
  quote       Quote?
  invoice     Invoice?

  @@unique([companyId, jobNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, scheduledAt])
}

model JobLineItem {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Decimal  @db.Decimal(10, 3)
  unitCost    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  recurringInterval RecurringInterval? // display-only snapshot from the price book
  sortOrder   Int      @default(0)

  @@index([jobId])
}

// A single required task on a job, materialized from the checklists of the
// price-book services on its line items (lib/job-checklist.ts syncs them by
// service name). Every item must be done OR carry a skip reason before the
// job can leave ACTIVE (enforced in the job status route).
model JobChecklistItem {
  id         String    @id @default(cuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  label      String
  // Name of the price-book service this task came from — the sync key.
  sourceName String
  sortOrder  Int       @default(0)
  doneAt     DateTime?
  doneById   String?
  doneBy     User?     @relation(fields: [doneById], references: [id])
  // Why this task was NOT done (mutually exclusive with doneAt in practice)
  skipReason String?
  createdAt  DateTime  @default(now())

  @@unique([jobId, sourceName, label])
  @@index([jobId])
}

model JobAssignment {
  id     String @id @default(cuid())
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@index([userId])
}

// ─── Time tracking ────────────────────────────────────────────────────────────

enum TimeEntrySource {
  CLOCK // live clock-in/out from the tech's device
  MANUAL // typed in or edited by a manager (forgotten clock-out, paper fix)
}

// One clock-in → clock-out span for a user on a job. endedAt null = currently
// on the clock; at most one open entry per user, enforced in the clock route
// (a new clock-in auto-closes any prior open entry). GPS fields are single
// point-in-time stamps captured at the moment of the tap — never continuous
// tracking, and only while clocking. Job deletion keeps the hours (SetNull)
// so payroll totals survive.
model TimeEntry {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  startedAt DateTime
  endedAt   DateTime?
  source    TimeEntrySource @default(CLOCK)
  note      String?
  // Client-generated key so a retried/queued clock tap can't double-create
  clientKey String?   @unique
  // Location stamps (nullable — tech may deny location); accuracy in meters
  startLat      Float?
  startLng      Float?
  startAccuracy Float?
  endLat        Float?
  endLng        Float?
  endAccuracy   Float?
  // Manager who last hand-edited this entry (audit trail for payroll)
  editedById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  locationPings LocationPing[]

  @@index([companyId, startedAt])
  @@index([companyId, endedAt])
  @@index([userId, endedAt])
  @@index([jobId])
}

// Team-map position report, posted by the app every few minutes WHILE (and
// only while) the user is clocked in with the app in the foreground — the
// server rejects pings with no open TimeEntry, so location is structurally
// impossible to collect off the clock. Short retention: the cron prunes pings
// older than 30 days (location history is a liability, not an asset).
model LocationPing {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeEntryId String?
  timeEntry   TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  lat         Float
  lng         Float
  accuracy    Float? // meters
  recordedAt  DateTime   @default(now())

  @@index([companyId, recordedAt])
  @@index([userId, recordedAt])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([jobId])
}

enum PhotoType {
  BEFORE
  AFTER
  GENERAL
}

model JobPhoto {
  id        String    @id @default(cuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  type      PhotoType @default(GENERAL)
  // Uploaded photo bytes served via /api/job-photos/[id] (client-side resized
  // JPEG, same pattern as Company.logoData; move both to R2 when volume grows)
  data      Bytes?
  mimeType  String?
  createdAt DateTime  @default(now())

  @@index([jobId])
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  AWAITING_RESPONSE
  APPROVED
  CHANGES_REQUESTED
  CONVERTED
  ARCHIVED
}

enum DepositType {
  NONE
  PERCENT
  FIXED
  FULL // all payment due upfront (deposit equals the full total)
}

model Quote {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id])
  requestId     String?
  request       Request?    @relation(fields: [requestId], references: [id])
  jobId         String?     @unique // set when this quote is converted into a job
  job           Job?        @relation(fields: [jobId], references: [id])
  quoteNumber   Int
  title         String?
  // Discount applies to the subtotal before tax; carries to the invoice
  discountType  DepositType @default(NONE)
  discountValue Decimal?    @db.Decimal(10, 2)
  discount      Decimal?    @db.Decimal(10, 2) // computed amount
  status        QuoteStatus @default(DRAFT)
  subtotal      Decimal     @db.Decimal(10, 2)
  taxRate       Decimal?    @db.Decimal(5, 4)
  tax           Decimal?    @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  depositType   DepositType @default(NONE)
  depositValue  Decimal?    @db.Decimal(10, 2) // percent (0-100) or fixed dollars
  clientMessage String?
  disclaimer    String?
  notes         String?
  validUntil    DateTime?
  sentAt        DateTime?
  // Client opened the public /quote page (beacon-stamped, own-company previews
  // excluded — see /api/public/viewed). First view pushes the team.
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int         @default(0)
  approvedAt    DateTime?
  signatureName String?
  changeRequest String?
  publicToken   String      @unique @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lineItems QuoteLineItem[]
  contracts Contract[]
  invoices  Invoice[] // deposit (and any other) invoices issued against this quote

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([contactId])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name        String  @default("")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitCost    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  isOptional  Boolean @default(false)
  optedOut    Boolean @default(false) // client unchecked this optional item in the hub
  // Snapshotted from WorkItem.requiresAgreement when picked from the price book
  requiresAgreement Boolean @default(false)
  // Source price-book item (when picked from the price book) — lets conversion
  // read the live recurring config; null for free-typed lines
  workItemId  String?
  // Snapshotted from WorkItem.recurringInterval — drives subscription creation
  // on conversion and the "Billed monthly" label on client-facing pages
  recurringInterval RecurringInterval?
  sortOrder   Int     @default(0)

  @@index([quoteId])
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  PAST_DUE
}

// Distinguishes a deposit invoice (collected up front against an approved quote)
// from a normal/final invoice. A quote's final invoice nets any PAID deposits.
enum InvoiceKind {
  STANDARD
  DEPOSIT
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  jobId         String?       @unique
  job           Job?          @relation(fields: [jobId], references: [id])
  // Set when this invoice was auto-generated by a recurring subscription cycle
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  // Deposit invoices link back to the quote they collect against, so the quote's
  // final invoice can find and net any paid deposits.
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id])
  kind          InvoiceKind   @default(STANDARD)
  invoiceNumber Int
  subject       String?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(10, 2)
  // Discount applies to the subtotal before tax
  discountType  DepositType   @default(NONE)
  discountValue Decimal?      @db.Decimal(10, 2)
  discount      Decimal?      @db.Decimal(10, 2) // computed amount
  taxRate       Decimal?      @db.Decimal(5, 4)
  tax           Decimal?      @db.Decimal(10, 2)
  surcharge     Decimal?      @db.Decimal(10, 2)
  // Deposit already paid on the originating quote, credited off this (final)
  // invoice. `total` is stored net of this; kept for the "Deposit applied" row.
  depositApplied Decimal?     @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  // Client opened the public /pay page (beacon-stamped — see /api/public/viewed)
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int           @default(0)
  publicToken   String        @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]
  reminders PaymentReminder[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([quoteId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String  @default("")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  serviceDate DateTime?
  workItemId  String? // source price-book item, when picked from the price book
  recurringInterval RecurringInterval? // display-only snapshot from the price book
  sortOrder   Int     @default(0)

  @@index([invoiceId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CARD
  ACH
  CASH
  CHECK
  CASH_APP
  PAYPAL
  VENMO
  ZELLE
  OTHER
}

model Payment {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id])
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  referenceNumber String?
  details         String?
  processorRef    String? // transaction id from the payment processor (card/ACH)
  surchargeAmount Decimal?      @db.Decimal(10, 2)
  // Platform-economics columns (superadmin profitability tracking). Only set
  // on processor-run payments; manual/check/cash rows stay null.
  feeCents        Int? // processing fee billed to the merchant (our gross revenue), from the fee profile at charge time
  cardBrand       String? // VISA / MASTERCARD / AMERICAN_EXPRESS ... from the Finix payment instrument
  cardType        String? // CREDIT / DEBIT — drives the interchange cost estimate
  estCostCents    Int? // estimated buy-rate cost (interchange + Finix margin); trued up monthly via FinixCostSnapshot
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@index([invoiceId])
  @@index([contactId])
}

model PaymentReminder {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String
  sentAt    DateTime

  @@unique([invoiceId, type])
  @@index([invoiceId])
}

// ─── Platform usage metering (superadmin cost tracking) ──────────────────────

// One row per company per UTC day, upserted with atomic increments by
// lib/usage.ts. companyId is a PLAIN string — deliberately no FK — so cost
// history survives company deletion; the sentinel "platform" collects sends
// that belong to no tenant (password resets, portal logins).
model CompanyUsageDaily {
  id             String   @id @default(cuid())
  companyId      String // Company.id, or "platform" for unattributed
  day            String // UTC date "2026-07-20" — lexicographic order == chronological
  aiCalls        Int      @default(0)
  aiTokensIn     Int      @default(0)
  aiTokensOut    Int      @default(0)
  aiTokensCached Int      @default(0)
  emailsSent     Int      @default(0)
  smsSent        Int      @default(0)
  smsSegments    Int      @default(0)
  storageBytes   BigInt? // nightly snapshot (photos + logos + avatars), not a counter
  updatedAt      DateTime @updatedAt

  @@unique([companyId, day])
  @@index([day])
}

// Monthly per-merchant ACTUALS imported from Finix's Net Profit report
// (dashboard-only CSV — Finix exposes no report API). Where a snapshot
// exists, /superadmin shows these numbers instead of estimates.
model FinixCostSnapshot {
  id                   String   @id @default(cuid())
  finixMerchantId      String
  month                String // "2026-07"
  cardSaleCents        BigInt   @default(0)
  echeckSaleCents      BigInt   @default(0)
  cardFeesCents        BigInt   @default(0) // fees billed to the merchant = our gross processing revenue
  interchangeFeesCents BigInt   @default(0) // actual interchange cost incurred
  residualCents        BigInt   @default(0) // Finix-reported net margin (the authoritative number)
  raw                  Json? // full CSV row, for columns not modeled here
  importedAt           DateTime @default(now())

  @@unique([finixMerchantId, month])
}

// ─── Price Book ───────────────────────────────────────────────────────────────

enum WorkItemType {
  SERVICE
  PRODUCT
}

// Subscription cadence for recurring services. SEMIANNUAL = every 6 months
// ("biannually"). Kept distinct from the job-scheduling Frequency enum, which
// is about how often a visit recurs (weekly/biweekly), not how often you bill.
enum RecurringInterval {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

// What the recurring engine does with each billing cycle's invoice.
enum RecurringInvoiceMode {
  SEND // auto-send (auto-charge a card on file once the processor is live, else email a pay link)
  DRAFT // mint a draft invoice for the company to review and send manually
}

// When an attached agreement is auto-sent to the client.
enum AgreementTiming {
  WITH_QUOTE // send as soon as the quote goes out
  ON_APPROVAL // send only once the quote is approved
}

// How a service's price is presented to homeowners (booking form + client
// pages). Trades rarely flat-rate everything: variable-scope work is quoted
// "starting at", T&M work is hourly, and big-ticket jobs hide the number
// behind a free estimate. unitPrice stays the numeric anchor either way.
enum PriceDisplay {
  FIXED // "$150.00" — flat rate per job
  STARTING_AT // "From $150" — final price depends on scope
  HOURLY // "$95/hr" — time & materials
  QUOTE // no number — "Free estimate / we'll quote it"
}

model WorkItem {
  id          String       @id @default(cuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  name        String
  description String?
  type        WorkItemType @default(SERVICE)
  unitCost    Decimal?     @db.Decimal(10, 2)
  unitPrice   Decimal      @default(0) @db.Decimal(10, 2)
  // How the price reads on client-facing surfaces (booking form)
  priceDisplay PriceDisplay @default(FIXED)
  // Preset deposit for this service. Snapshots onto quotes built from the price
  // book (summed across services) and drives the deposit invoice on approval.
  // NONE = fall back to the company default. FULL = whole line due upfront.
  depositType  DepositType @default(NONE)
  depositValue Decimal?    @db.Decimal(10, 2) // percent (0-100) or fixed dollars
  // How long this service takes on site — feeds the online-booking slot
  // engine. null = not offerable for self-scheduling.
  durationMinutes Int?
  // Recurring/subscription settings. null interval = one-time service.
  recurringInterval    RecurringInterval?
  recurringCreatesJob  Boolean              @default(false) // also spin up a job each cycle (visit-based work)
  recurringInvoiceMode RecurringInvoiceMode @default(SEND)
  // Quotes containing this service can't convert to a job until a linked
  // agreement is signed (flag snapshots onto QuoteLineItem at pick time).
  // Set automatically whenever an agreement template is attached.
  requiresAgreement Boolean @default(false)
  // Task list for this service (Json string[]). Jobs whose line items include
  // this service materialize these as JobChecklistItems, which must each be
  // checked off (or given a skip reason) before the job can be closed out.
  checklist Json?
  // Optional agreement that auto-sends with quotes for this service
  agreementTemplateId String?
  agreementTemplate   ContractTemplate? @relation(fields: [agreementTemplateId], references: [id])
  agreementTiming     AgreementTiming   @default(ON_APPROVAL)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subscriptions Subscription[]

  @@index([companyId])
  @@index([companyId, name])
}

// ─── Subscriptions (recurring services sold to a client) ─────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

// A live recurring agreement: created when a recurring price-book service is
// sold (quote→job, direct invoice, or web-form service request). The recurring
// engine (lib/subscriptions.ts) sweeps ACTIVE rows whose nextRunDate is due and
// generates the next invoice (and optionally a job). Snapshots name/price so it
// survives price-book edits/deletes.
model Subscription {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id])
  contactId   String
  contact     Contact            @relation(fields: [contactId], references: [id])
  workItemId  String?
  workItem    WorkItem?          @relation(fields: [workItemId], references: [id])
  name        String
  description String?
  unitPrice   Decimal            @db.Decimal(10, 2)
  quantity    Decimal            @default(1) @db.Decimal(10, 3)
  interval    RecurringInterval
  createsJob  Boolean            @default(false)
  invoiceMode RecurringInvoiceMode @default(SEND)
  status      SubscriptionStatus @default(ACTIVE)
  nextRunDate DateTime // date-only, noon-anchored; the engine bills when this is due
  lastGeneratedAt DateTime? // guards against double-billing on repeated/overlapping runs

  // ── Visit series (visit cadence decoupled from billing) ─────────────────────
  // "Weekly mows, billed monthly": visitFrequency generates visit jobs on its
  // own cadence while `interval` keeps billing. The engine materializes visits
  // on a rolling horizon so dispatchers see them on the calendar; each visit is
  // an ordinary Job (drag to reschedule / delete to skip — the series doesn't
  // care). null visitFrequency = no separate series (legacy createsJob applies).
  visitFrequency       Frequency?
  nextVisitDate        DateTime? // date-only, noon-anchored; next unmaterialized visit
  visitStartMinutes    Int? // minutes from midnight, company TZ; null = "Anytime"
  visitDurationMinutes Int? // visit window length in minutes; null = 60
  visitAssigneeIds     String[] @default([]) // default team copied onto generated visits
  lastVisitGeneratedAt DateTime?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  invoices Invoice[]
  jobs     Job[]

  @@index([companyId])
  @@index([companyId, status, nextRunDate])
  @@index([status, nextVisitDate])
  @@index([contactId])
}

// Visit cadence for a subscription's visit series (billing cadence lives in
// RecurringInterval — the two are deliberately separate enums).
enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

// ─── Booking Requests (legacy public booking form) ───────────────────────────

enum BookingStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

model BookingRequest {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  service       String
  preferredDate DateTime?
  message       String?
  status        BookingStatus @default(NEW)
  createdAt     DateTime      @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

// ─── Review Requests ──────────────────────────────────────────────────────────

model ReviewRequest {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  contactId String?
  jobId     String?
  email     String?
  phone     String?
  sentAt    DateTime
  method    String
  status    String   @default("sent")
  createdAt DateTime @default(now())

  @@index([companyId])
}

// ─── QuickBooks Online integration ───────────────────────────────────────────

// One QBO connection per company (Settings → QuickBooks). Tokens are
// AES-256-GCM encrypted at rest by lib/quickbooks.ts (key derived from
// AUTH_SECRET); realmId is Intuit's id for the connected company file.
// The sync is one-way push: Contact → Customer, Invoice → Invoice,
// Payment → Payment. Refresh tokens roll for ~100 days — a company that
// goes idle longer than that must reconnect (lastSyncError says so).
model QuickBooksConnection {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  realmId               String
  accessTokenEnc        String
  refreshTokenEnc       String
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  // Push invoices/payments as they happen + nightly cron sweep. Off = only
  // the manual "Sync now" button moves data.
  autoSync              Boolean  @default(true)
  qboCompanyName        String? // CompanyInfo display name, shown in settings
  // Lazily resolved on first sync: the generic Service item our invoice lines
  // bill against ("Streamflaire Services") and the income account behind it.
  defaultItemId         String?
  incomeAccountId       String?
  lastSyncAt            DateTime?
  lastSyncError         String? // most recent connection-level failure; null = healthy
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  syncRecords QuickBooksSyncRecord[]
}

enum QuickBooksEntityType {
  CUSTOMER
  INVOICE
  PAYMENT
}

enum QuickBooksSyncStatus {
  SYNCED
  ERROR
}

// Local row ↔ QBO entity mapping. qboSyncToken is QBO's optimistic-lock
// version, required on every update; localUpdatedAt is the local row's
// updatedAt at push time — a newer local updatedAt means re-push.
model QuickBooksSyncRecord {
  id             String               @id @default(cuid())
  connectionId   String
  connection     QuickBooksConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  companyId      String
  entityType     QuickBooksEntityType
  localId        String
  qboId          String?
  qboSyncToken   String?
  status         QuickBooksSyncStatus @default(SYNCED)
  error          String?
  localUpdatedAt DateTime?
  lastSyncedAt   DateTime             @default(now())

  @@unique([companyId, entityType, localId])
  @@index([connectionId])
  @@index([companyId, status])
}

// ─── Invite-gated onboarding ─────────────────────────────────────────────────

// A single-use code that authorizes one company signup. Minted by a
// superadmin — directly from /superadmin/invites or by approving an
// AccessApplication — and required by /api/app/register.
model InviteCode {
  id              String    @id @default(cuid())
  code            String    @unique // human-typable, e.g. WB-7K2M-9QX4
  note            String? // superadmin's memo: who this is for
  email           String? // where it was sent — informational, not enforced
  expiresAt       DateTime? // null = never expires
  usedAt          DateTime?
  usedByCompanyId String?   @unique
  usedByCompany   Company?  @relation(fields: [usedByCompanyId], references: [id], onDelete: SetNull)
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  applicationId String?            @unique
  application   AccessApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Public /apply form submissions, reviewed at /superadmin/applications.
// Approving one mints an InviteCode and emails it to the applicant.
model AccessApplication {
  id          String            @id @default(cuid())
  name        String
  email       String
  phone       String?
  companyName String
  industry    String?
  teamSize    String?
  website     String?
  message     String?
  // Payment-intent screening (2026-07): every company must pass Finix
  // underwriting, so the application asks up front whether they're a real
  // business that will actually run card volume.
  city            String?
  state           String?
  paymentsToday   String? // how they collect payment now (cash-only is a flag)
  monthlyVolume   String? // monthly invoicing range — our revenue forecast
  yearsInBusiness String?
  entityType      String? // LLC/corp vs sole prop vs not registered
  status      ApplicationStatus @default(PENDING)
  decidedAt   DateTime?
  createdAt   DateTime          @default(now())

  inviteCode InviteCode?

  @@index([status])
}
